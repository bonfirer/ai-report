# ── AI Report Platform — server configuration ──
# Copy this file to `.env` and fill in real values. Never commit your `.env`.

# MySQL / MariaDB connection for the platform's metadata database.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Note: URL-encode special characters in the password (e.g. '@' -> %40).
DATABASE_URL=mysql://ai_report:change-me@127.0.0.1:3306/ai_report

# Secret used to sign JWT auth tokens. MUST be at least 16 characters.
# Generate a strong random value, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# CORS allowed origin. Use "*" for local development, or your site origin
# (e.g. https://example.com) in production. Optional; defaults to "*".
CORS_ALLOWED_ORIGIN=*

# The LLM provider (OpenAI-compatible / DeepSeek), API key, model, etc. are
# configured at runtime in the app's Settings page and stored in the database,
# so they do not need to be set here.
