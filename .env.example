# ── Docker Compose configuration ──
# Copy to `.env` (same directory as docker-compose.yml) to override defaults.
# All values are optional; the stack runs with the defaults below out of the box.

# Public port the web UI is served on.
WEB_PORT=9528

# Metadata database (MySQL). The db container is NOT exposed to the host, so
# these only matter inside the compose network — but change them for anything
# beyond local evaluation.
MYSQL_DATABASE=ai_report
MYSQL_USER=aireport
MYSQL_PASSWORD=aireport_local_pw
MYSQL_ROOT_PASSWORD=root_local_pw

# Auth token signing secret. Leave EMPTY to have the server auto-generate and
# persist a strong random secret in its data volume on first run. Set an
# explicit value (>= 16 chars) if you prefer to manage it yourself.
JWT_SECRET=

# Allowed CORS origin. Use "*" for local; set your site origin in production,
# e.g. https://reports.example.com
CORS_ALLOWED_ORIGIN=*
